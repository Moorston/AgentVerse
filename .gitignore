# ============================================
# AgentVerse .gitignore
# ============================================

# ─── Python ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.pytest_cache/
.coverage
.coverage.*
coverage/
htmlcov/
.mypy_cache/
.ruff_cache/
.venv/
.venv.bak/
uv.lock
*.so

# ─── Node.js / Next.js ─────────────────────
node_modules/
.next/
.nuxt/
out/
*.tsbuildinfo
next-env.d.ts

# ─── IDE / Editor ──────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ─── OS ────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Environment / Secrets ─────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key

# ─── Docker ────────────────────────────────
.docker/
docker-compose.override.yml

# ─── Trellis / OpenSpec / Claude Code ──────
.trellis/workspace/
.trellis/tasks/*/
openspec/changes/archive/
.cursor/
.claude/projects/

# ─── Logs ──────────────────────────────────
*.log
logs/

# ─── Misc ──────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
