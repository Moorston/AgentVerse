# === Environment ===
ENVIRONMENT=development
LOG_LEVEL=INFO

# === Neo4j ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=agentverse_dev

# === PostgreSQL (pgvector) ===
POSTGRES_DSN=postgresql+asyncpg://agentverse:agentverse_dev@localhost:5432/agentverse
POSTGRES_USER=agentverse
POSTGRES_PASSWORD=agentverse_dev
POSTGRES_DB=agentverse

# === LLM Providers ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# === Embedding ===
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536